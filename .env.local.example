# .env.local.example — copy to .env.local and customize
# .env.local is gitignored (machine-specific, never committed)

# Serial monitor baud rate (default: 921600)
# MONITOR_BAUD=921600

# Bridge UDP ports (defaults match architecture spec)
# OSC_PORT_PRIMARY=9000
# OSC_PORT_DEBUG=9500
# OSC_PORT_LED_IN=9001

# Path to your Ableton Live project (Google Drive)
# Uncomment and adjust for your machine:
# ABLETON_PROJECT=~/Google Drive/Music Kendama/Ableton/Music Kendama Live Set/

# Machine identifier (for your own reference, not used by any tool)
# MACHINE=macbook-pro
# MACHINE=macbook-air
